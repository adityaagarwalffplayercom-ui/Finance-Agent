generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String                @id @default(cuid())
  name          String
  email         String                @unique
  emailVerified Boolean               @default(false)
  image         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  accounts      Account[]
  auditEvents   AuditEvent[]
  business      Business?
  chatMessages  BusinessChatMessage[]
  documents     Document[]
  ledgerEntries LedgerEntry[]
  sessions      Session[]
  usageEvents   UsageEvent[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Business {
  id            String   @id @default(cuid())
  name          String
  industry      String?
  businessType  String?
  financialYear String?
  currency      String   @default("INR")
  country       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business")
}

model Document {
  id              String               @id @default(cuid())
  fileName        String
  mimeType        String
  fileSize        Int
  category        DocumentCategory
  status          DocumentStatus       @default(UPLOADED)
  content         Bytes
  extractedData   Json?
  extractedAt     DateTime?
  processingError String?
  uploadedAt      DateTime             @default(now())
  userId          String
  reviewNote      String?
  reviewStatus    DocumentReviewStatus @default(NEEDS_REVIEW)
  reviewedAt      DateTime?
  ledgerEntries   LedgerEntry[]
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, uploadedAt])
  @@index([userId, status, reviewStatus])
  @@map("document")
}

model BusinessChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("business_chat_message")
}

model UsageEvent {
  id        String   @id @default(cuid())
  eventType String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType, createdAt])
  @@map("usage_event")
}

model AuditEvent {
  id          String   @id @default(cuid())
  eventType   String
  title       String
  description String?
  documentId  String?
  fileName    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, eventType, createdAt])
  @@map("audit_event")
}

model TaxRule {
  id                 String              @id @default(cuid())
  countryCode        String
  countryName        String
  financialYear      String
  taxType            TaxRuleType
  ruleKey            String
  title              String
  summary            String
  ruleText           String
  sourceName         String
  sourceUrl          String
  sourcePublishedAt  DateTime?
  effectiveFrom      DateTime?
  effectiveTo        DateTime?
  lastVerifiedAt     DateTime?
  verificationStatus TaxRuleStatus       @default(DRAFT)
  verifiedBy         String?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sourceLinks        TaxRuleSourceLink[]

  @@unique([countryCode, financialYear, taxType, ruleKey])
  @@index([countryCode, financialYear, taxType, verificationStatus])
  @@index([verificationStatus, lastVerifiedAt])
  @@map("tax_rule")
}

model TaxSourceDocument {
  id                 String              @id @default(cuid())
  countryCode        String
  countryName        String
  financialYear      String
  taxType            TaxRuleType
  title              String
  sourceName         String
  sourceUrl          String?
  fileName           String?
  mimeType           String?
  originalText       String
  verificationStatus TaxRuleStatus       @default(DRAFT)
  uploadedBy         String?
  lastVerifiedAt     DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  chunks             TaxKnowledgeChunk[]
  ruleLinks          TaxRuleSourceLink[]

  @@index([countryCode, financialYear, taxType, verificationStatus])
  @@index([verificationStatus, lastVerifiedAt])
  @@map("tax_source_document")
}

model TaxKnowledgeChunk {
  id                 String            @id @default(cuid())
  sourceDocumentId   String
  countryCode        String
  countryName        String
  financialYear      String
  taxType            TaxRuleType
  chunkIndex         Int
  title              String
  content            String
  sourceName         String
  sourceUrl          String?
  verificationStatus TaxRuleStatus     @default(DRAFT)
  lastVerifiedAt     DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  sourceDocument     TaxSourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)

  @@index([countryCode, financialYear, taxType, verificationStatus])
  @@index([sourceDocumentId, chunkIndex])
  @@map("tax_knowledge_chunk")
}

model TaxRuleSourceLink {
  id               String            @id @default(cuid())
  taxRuleId        String
  sourceDocumentId String
  createdAt        DateTime          @default(now())
  sourceDocument   TaxSourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  taxRule          TaxRule           @relation(fields: [taxRuleId], references: [id], onDelete: Cascade)

  @@unique([taxRuleId, sourceDocumentId])
  @@index([sourceDocumentId])
  @@map("tax_rule_source_link")
}

model LedgerEntry {
  id              String            @id @default(cuid())
  transactionDate DateTime?
  description     String
  counterparty    String?
  category        String?
  direction       LedgerDirection
  amount          Decimal           @db.Decimal(20, 2)
  currency        String            @default("INR")
  confidence      Float?
  status          LedgerEntryStatus @default(NEEDS_REVIEW)
  sourceType      LedgerSourceType
  sourceLineKey   String
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  userId          String
  documentId      String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  document        Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, sourceLineKey])
  @@index([userId, transactionDate])
  @@index([userId, direction, status])
  @@index([documentId])
  @@map("ledger_entry")
}

enum LedgerDirection {
  CREDIT
  DEBIT
  NEUTRAL
}

enum LedgerEntryStatus {
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum LedgerSourceType {
  BANK_TRANSACTION
  DOCUMENT_LINE
  STATEMENT_LINE
  DOCUMENT_TOTAL
  MANUAL
}

enum DocumentCategory {
  BANK_STATEMENT
  SALES_INVOICE
  PURCHASE_INVOICE
  PAYROLL
  UTILITY_BILL
  FINANCIAL_STATEMENT
  OTHER
  RECEIPT
  CREDIT_NOTE
  DEBIT_NOTE
  TAX_DOCUMENT
  GST_RETURN
  LOAN_STATEMENT
  RENT_LEASE
  INSURANCE_DOCUMENT
  INVENTORY_REPORT
  PURCHASE_ORDER
  SALES_ORDER
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum DocumentReviewStatus {
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum TaxRuleType {
  INCOME_TAX
  GST
  VAT
  SALES_TAX
  CORPORATE_TAX
  PAYROLL_TAX
  DEDUCTION
  FILING
  COMPLIANCE
  OTHER
}

enum TaxRuleStatus {
  DRAFT
  VERIFIED
  NEEDS_REVIEW
  ARCHIVED
}
