# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/aureli?sslmode=require"
DIRECT_URL="postgresql://user:password@host/aureli?sslmode=require"

# ─────────────────────────────────────────────────────────────
# Application and authentication
# ─────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-a-random-32-byte-secret"
BETTER_AUTH_TRUSTED_ORIGINS="http://127.0.0.1:3000"
BETTER_AUTH_REQUIRE_EMAIL_VERIFICATION="false"
NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION="false"
AUTH_RATE_LIMIT_STORAGE="database"

# Email delivery for verification, invitations and password reset
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Aureli <no-reply@example.com>"

# ─────────────────────────────────────────────────────────────
# Gemini
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY="replace-with-your-gemini-api-key"
GEMINI_MODEL="gemini-3.1-flash-lite"
GEMINI_FALLBACK_MODELS=""
GEMINI_MAX_PDF_CHUNKS="3"

# ─────────────────────────────────────────────────────────────
# Private S3-compatible object storage
# Works with AWS S3, Cloudflare R2, Backblaze B2 and compatible providers.
# Use a private bucket and configure CORS for your application origin.
# ─────────────────────────────────────────────────────────────
DIRECT_UPLOADS_ENABLED="false"
OBJECT_STORAGE_REQUIRED="false"
OBJECT_STORAGE_ENDPOINT="https://s3.amazonaws.com"
OBJECT_STORAGE_BUCKET=""
OBJECT_STORAGE_REGION="us-east-1"
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""

# ─────────────────────────────────────────────────────────────
# Durable processing queue and scheduled jobs
# Local development can use inline. Production should use queue.
# ─────────────────────────────────────────────────────────────
DOCUMENT_PROCESSING_MODE="inline"
JOB_WORKER_SECRET="replace-with-a-long-random-secret"
CRON_SECRET="replace-with-a-long-random-secret"
MAX_JOBS_PER_INVOCATION="2"
STALE_JOB_MINUTES="15"
MAX_PDF_PAGES="500"

# ─────────────────────────────────────────────────────────────
# Privacy, retention and production safety
# ─────────────────────────────────────────────────────────────
DEFAULT_RETENTION_DAYS="365"
REQUIRE_AI_PROCESSING_CONSENT="false"
STRICT_PRODUCTION_ENV="false"
ENABLE_DEBUG_ROUTES="false"
ADMIN_EMAILS=""
ADMIN_API_SECRET=""

# Optional structured error reporting provider DSN. The built-in logger works
# without this; wire this value to the monitoring provider selected for deployment.
OBSERVABILITY_WEBHOOK_URL=""
OBSERVABILITY_WEBHOOK_SECRET=""

# Optional malware scanning webhook. It receives a short-lived private download URL
# and must return JSON like {"clean":true,"provider":"...","reference":"..."}.
MALWARE_SCAN_WEBHOOK_URL=""
MALWARE_SCAN_WEBHOOK_SECRET=""
MALWARE_SCAN_REQUIRED="false"
