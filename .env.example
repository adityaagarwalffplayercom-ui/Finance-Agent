# PostgreSQL connection string.
# Local:   postgresql://user:password@localhost:5432/finance_platform
# Hosted:  use the connection string your provider (Neon, Supabase, Railway...) gives you
DATABASE_URL="postgresql://user:password@localhost:5432/finance_platform"

# Signs and encrypts session cookies. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-random-32-byte-secret"

# The base URL of this app, used server-side by Better Auth.
BETTER_AUTH_URL="http://localhost:3000"

# Same URL, exposed to the browser for the auth client.
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
