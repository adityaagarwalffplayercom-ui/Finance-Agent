# Pooled PostgreSQL connection used by the running application.
# For Neon, use the pooled connection string provided by the dashboard.
DATABASE_URL="postgresql://user:password@host/finance_platform?sslmode=require"

# Direct PostgreSQL connection used by Prisma migrations and schema operations.
# For Neon, use the non-pooling/direct connection string.
DIRECT_URL="postgresql://user:password@host/finance_platform?sslmode=require"

# Generate a strong value with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Public URL of the application.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Optional comma-separated additional origins allowed by Better Auth.
BETTER_AUTH_TRUSTED_ORIGINS="http://127.0.0.1:3000"

# Google Gemini configuration.
GEMINI_API_KEY="replace-with-your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash-lite"

# Optional comma-separated fallback model names, attempted in order.
GEMINI_FALLBACK_MODELS=""

# Optional administrative and scheduled-job protection.
ADMIN_EMAILS=""
ADMIN_API_SECRET=""
CRON_SECRET=""
