  padding-left: 24px !important;
  padding-right: 24px !important;
}

form:has(input[type="email"]):has(input[type="password"]) button * {
  margin-left: auto !important;
  margin-right: auto !important;
  text-align: center !important;
}

/* AUTH BUTTON CENTER END */


/* AURELI MINIMAL LIQUID UI START */

/* Global minimal liquid design tokens */
:root {
  --aureli-bg-0: #07080b;
  --aureli-bg-1: #0b0d12;
  --aureli-bg-2: #11141b;

  --aureli-glass-1: rgba(255, 255, 255, 0.055);
  --aureli-glass-2: rgba(255, 255, 255, 0.085);
  --aureli-glass-3: rgba(255, 255, 255, 0.12);

  --aureli-border: rgba(255, 255, 255, 0.105);
  --aureli-border-soft: rgba(255, 255, 255, 0.07);

  --aureli-text: rgba(255, 255, 255, 0.94);
  --aureli-muted: rgba(255, 255, 255, 0.62);
  --aureli-faint: rgba(255, 255, 255, 0.42);

  --aureli-gold: #f0cf82;
  --aureli-gold-soft: rgba(240, 207, 130, 0.18);
  --aureli-green: #76e4b1;
  --aureli-red: #ff8f8f;

  --aureli-radius-sm: 16px;
  --aureli-radius: 24px;
  --aureli-radius-lg: 34px;
  --aureli-radius-xl: 44px;

  --aureli-shadow-soft:
    0 20px 60px rgba(0, 0, 0, 0.28),
    inset 0 1px 0 rgba(255, 255, 255, 0.075);

  --aureli-shadow-card:
    0 24px 80px rgba(0, 0, 0, 0.34),
    inset 0 1px 0 rgba(255, 255, 255, 0.09);
}

/* Page background */
html,
body {
  background:
    radial-gradient(circle at 15% 0%, rgba(240, 207, 130, 0.09), transparent 28%),
    radial-gradient(circle at 90% 10%, rgba(130, 170, 255, 0.08), transparent 30%),
    radial-gradient(circle at 50% 100%, rgba(118, 228, 177, 0.045), transparent 30%),
    linear-gradient(180deg, var(--aureli-bg-1), var(--aureli-bg-0)) !important;
  color: var(--aureli-text) !important;
}

/* Smooth font rendering */
* {
  -webkit-font-smoothing: antialiased;
  text-rendering: geometricPrecision;
}

/* Main app shell */
main,
[data-main],
.app-shell,
.dashboard-shell {
  background: transparent !important;
}

/* Generic liquid cards / boxes */
section,
article,
.card,
.panel,
.dashboard-card,
.metric-card,
.agent-card,
.document-card,
.upload-card,
.review-card,
.tax-card,
[class*="card"],
[class*="Card"],
[class*="panel"],
[class*="Panel"] {
  border-color: var(--aureli-border-soft) !important;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.078), rgba(255, 255, 255, 0.036)) !important;
  box-shadow: var(--aureli-shadow-soft) !important;
  backdrop-filter: blur(26px) saturate(1.25) !important;
  -webkit-backdrop-filter: blur(26px) saturate(1.25) !important;
}

/* Rounded premium surfaces */
[class*="rounded"],
section,
article,
.card,
.panel,
.dashboard-card,
.metric-card,
.agent-card,
.document-card {
  border-radius: var(--aureli-radius) !important;
}

/* Bigger hero/workspace containers */
[class*="rounded-3xl"],
[class*="rounded-[32px]"],
[class*="rounded-[36px]"],
[class*="rounded-[40px]"] {
  border-radius: var(--aureli-radius-xl) !important;
}

/* Text hierarchy */
h1,
h2,
h3,
h4 {
  color: rgba(255, 255, 255, 0.96) !important;
  letter-spacing: -0.055em !important;
}

p,
span,
li {
  color: inherit;
}

.text-white\/60,
.text-white\/50,
.text-white\/40,
[class*="text-white/60"],
[class*="text-white/50"],
[class*="text-white/40"],
.text-slate-400,
.text-slate-500,
.text-zinc-400,
.text-neutral-400 {
  color: var(--aureli-muted) !important;
}

/* Sidebar liquid glass */
aside,
nav[aria-label="Sidebar"],
.sidebar,
.app-sidebar,
[data-sidebar],
[class*="sidebar"],
[class*="Sidebar"] {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.032)) !important;
  border: 1px solid var(--aureli-border-soft) !important;
  box-shadow:
    22px 0 70px rgba(0, 0, 0, 0.22),
    inset 1px 0 0 rgba(255, 255, 255, 0.08) !important;
  backdrop-filter: blur(30px) saturate(1.25) !important;
  -webkit-backdrop-filter: blur(30px) saturate(1.25) !important;
}

/* Sidebar links/items */
aside a,
aside button,
nav a,
nav button,
.sidebar a,
.sidebar button,
[data-sidebar] a,
[data-sidebar] button,
[class*="sidebar"] a,
[class*="sidebar"] button,
[class*="Sidebar"] a,
[class*="Sidebar"] button {
  border-radius: 18px !important;
  color: rgba(255, 255, 255, 0.72) !important;
  transition:
    background 0.2s ease,
    color 0.2s ease,
    transform 0.2s ease,
    border-color 0.2s ease !important;
}

/* Sidebar hover */
aside a:hover,
aside button:hover,
nav a:hover,
nav button:hover,
.sidebar a:hover,
.sidebar button:hover,
[data-sidebar] a:hover,
[data-sidebar] button:hover,
[class*="sidebar"] a:hover,
[class*="sidebar"] button:hover,
[class*="Sidebar"] a:hover,
[class*="Sidebar"] button:hover {
  background: rgba(255, 255, 255, 0.08) !important;
  color: rgba(255, 255, 255, 0.96) !important;
  transform: translateX(2px);
}

/* Active sidebar-like items */
aside [aria-current="page"],
nav [aria-current="page"],
.sidebar [aria-current="page"],
[data-sidebar] [aria-current="page"],
[class*="active"],
[class*="Active"] {
  background:
    linear-gradient(135deg, rgba(240, 207, 130, 0.22), rgba(255, 255, 255, 0.075)) !important;
  color: rgba(255, 255, 255, 0.98) !important;
  border-color: rgba(240, 207, 130, 0.22) !important;
}

/* Buttons */
button,
a[role="button"],
.btn,
[class*="button"],
[class*="Button"] {
  border-radius: 999px !important;
  border-color: rgba(255, 255, 255, 0.11) !important;
  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease,
    filter 0.2s ease,
    background 0.2s ease !important;
}

button:hover,
a[role="button"]:hover,
.btn:hover,
[class*="button"]:hover,
[class*="Button"]:hover {
  transform: translateY(-1px);
}

/* Primary-looking buttons */
button[type="submit"],
.bg-amber-400,
.bg-yellow-400,
.bg-orange-400,
[class*="bg-amber"],
[class*="bg-yellow"],
[class*="bg-orange"] {
  background:
    linear-gradient(135deg, #fff1b8 0%, #e6c060 46%, #9b6a22 100%) !important;
  color: #17130b !important;
  border: 0 !important;
  box-shadow:
    0 18px 45px rgba(214, 164, 67, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.55) !important;
}

/* Inputs, selects, textareas */
input,
select,
textarea {
  border-radius: 20px !important;
  border: 1px solid rgba(255, 255, 255, 0.105) !important;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.085), rgba(255, 255, 255, 0.045)) !important;
  color: rgba(255, 255, 255, 0.94) !important;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.08),
    0 14px 35px rgba(0, 0, 0, 0.16) !important;
  outline: none !important;
}

input::placeholder,
textarea::placeholder {
  color: rgba(255, 255, 255, 0.45) !important;
}

input:focus,
select:focus,
textarea:focus {
  border-color: rgba(240, 207, 130, 0.58) !important;
  box-shadow:
    0 0 0 4px rgba(240, 207, 130, 0.11),
    inset 0 1px 0 rgba(255, 255, 255, 0.12),
    0 18px 45px rgba(0, 0, 0, 0.22) !important;
}

/* Tables */
table {
  border-collapse: separate !important;
  border-spacing: 0 10px !important;
}

thead,
thead tr,
th {
  background: transparent !important;
  color: rgba(255, 255, 255, 0.5) !important;
  border: 0 !important;
}

tbody tr {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.03)) !important;
  border-radius: 18px !important;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.055) !important;
}

td {
  border: 0 !important;
  color: rgba(255, 255, 255, 0.78) !important;
}

/* Badges */
.badge,
[class*="badge"],
[class*="Badge"] {
  border-radius: 999px !important;
  background: rgba(255, 255, 255, 0.075) !important;
  border: 1px solid rgba(255, 255, 255, 0.08) !important;
  color: rgba(255, 255, 255, 0.78) !important;
}

/* Status colors minimal */
.text-green-400,
.text-emerald-400,
[class*="text-green"],
[class*="text-emerald"] {
  color: var(--aureli-green) !important;
}

.text-red-400,
.text-rose-400,
[class*="text-red"],
[class*="text-rose"] {
  color: var(--aureli-red) !important;
}

.text-amber-400,
.text-yellow-400,
[class*="text-amber"],
[class*="text-yellow"] {
  color: var(--aureli-gold) !important;
}

/* Remove harsh borders/backgrounds from Tailwind utility surfaces */
.border-white\/10,
.border-white\/15,
.border-white\/20,
.border-slate-800,
.border-zinc-800,
.border-neutral-800,
[class*="border-white/"],
[class*="border-slate"],
[class*="border-zinc"],
[class*="border-neutral"] {
  border-color: var(--aureli-border-soft) !important;
}

.bg-white\/5,
.bg-white\/10,
.bg-slate-900,
.bg-slate-950,
.bg-zinc-900,
.bg-neutral-900,
[class*="bg-white/5"],
[class*="bg-white/10"],
[class*="bg-slate-9"],
[class*="bg-zinc-9"],
[class*="bg-neutral-9"] {
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.068), rgba(255, 255, 255, 0.032)) !important;
}

/* Modals/dropdowns */
[role="dialog"],
[role="menu"],
.dropdown,
.popover,
.modal,
[class*="dropdown"],
[class*="Dropdown"],
[class*="popover"],
[class*="Popover"],
[class*="modal"],
[class*="Modal"] {
  background:
    linear-gradient(145deg, rgba(24, 27, 35, 0.92), rgba(12, 14, 19, 0.9)) !important;
  border: 1px solid rgba(255, 255, 255, 0.105) !important;
  border-radius: 26px !important;
  box-shadow: 0 28px 90px rgba(0, 0, 0, 0.42) !important;
  backdrop-filter: blur(30px) saturate(1.25) !important;
  -webkit-backdrop-filter: blur(30px) saturate(1.25) !important;
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.13);
  border-radius: 999px;
  border: 3px solid transparent;
  background-clip: content-box;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.22);
  border: 3px solid transparent;
  background-clip: content-box;
}

/* Auth page stays clean with liquid style */
form:has(input[type="email"]):has(input[type="password"]) {
  background: transparent !important;
  box-shadow: none !important;
}

form:has(input[type="email"]):has(input[type="password"]) button {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;
}

/* Small-screen polish */
@media (max-width: 768px) {
  section,
  article,
  .card,
  .panel,
  [class*="card"],
  [class*="Card"],
  [class*="panel"],
  [class*="Panel"] {
    border-radius: 22px !important;
  }

  input,
  select,
  textarea {
    border-radius: 18px !important;
  }
}

/* AURELI MINIMAL LIQUID UI END */
