/* Executive summary long green action bar fix */
.dashboard-main [style*="rgba(46,213,115"] {
  min-width: 0;
}

/* Fix report/document metric cards */
.dashboard-main [style*="CHF"],
.dashboard-main [style*="100/100"] {
  max-width: 100%;
}

/* Remove remaining blue feeling from cards */
.dashboard-main [style*="88,166,255"],
.dashboard-main [style*="#8abfff"],
