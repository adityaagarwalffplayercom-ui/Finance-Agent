  min-width: 0;
}

.dashboard-main aside article {
  min-width: 0;
  max-width: 100%;
}

.dashboard-main aside p {
  max-width: 100%;
  overflow-wrap: anywhere;
}

/* Sidebar alignment fix */
.sidebar {
  width: 280px;
  min-width: 280px;
  max-width: 280px;
  overflow-x: hidden;
}

.sidebar-nav {
  width: 100%;
}

.sidebar-link {
  width: 100%;
  min-width: 0;
  justify-content: flex-start;
  text-align: left;
}

.sidebar-link span,
