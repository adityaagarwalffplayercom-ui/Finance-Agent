.dashboard-main textarea,
.dashboard-main select,
.dashboard-main button {
  max-width: 100%;
}

/* Custom dropdown/form fields should not overflow */
.dashboard-main [role="button"],
.dashboard-main [role="listbox"],
.dashboard-main [role="option"] {
  max-width: 100%;
}

