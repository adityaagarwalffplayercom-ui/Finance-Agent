.page {
  display: grid;
  gap: 18px;
  min-width: 0;
  padding: 0 6px 24px 0;
}

.hero {
  position: relative;
  isolation: isolate;
  overflow: hidden;
  min-width: 0;
  padding: 28px !important;
  border: 1px solid rgba(210, 220, 240, 0.11) !important;
  border-radius: 30px !important;
  background:
    linear-gradient(
      135deg,
      rgba(30, 37, 49, 0.98),
      rgba(20, 26, 36, 0.98)
    ) !important;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.045),
    0 24px 60px rgba(0, 0, 0, 0.18) !important;
}

.heroGlow {
  position: absolute;
  z-index: -1;
  top: -180px;
  right: -110px;
  width: 520px;
  height: 520px;
  pointer-events: none;
  border-radius: 50%;
  background:
    radial-gradient(
      circle,
      rgba(82, 111, 148, 0.24),
      rgba(82, 111, 148, 0.06) 46%,
      transparent 72%
    );
}

.heroContent {
  display: grid;
  gap: 26px;
}

.heroTop {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
}

.heroCopy {
  display: grid;
  gap: 10px;
  max-width: 820px;
}

.titleRow {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
}

.eyebrow,
.surfaceEyebrow,
.emptyEyebrow {
  color: rgba(157, 179, 207, 0.94);
  font-size: 10px;
  font-weight: 950;
  letter-spacing: 0.13em;
  text-transform: uppercase;
}

.livePill {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 5px 9px;
  color: rgba(197, 220, 246, 0.92);
  border: 1px solid rgba(112, 145, 184, 0.27);
  border-radius: 999px;
  background: rgba(70, 91, 120, 0.14);
  font-size: 10px;
  font-weight: 850;
}

.liveDot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-sage, #69a88b);
  box-shadow: 0 0 10px rgba(105, 168, 139, 0.82);
}

.title {
  margin: 0;
  color: var(--color-text-primary, #f4f6f8);
  font-size: clamp(38px, 4.6vw, 64px);
  line-height: 0.96;
  letter-spacing: -0.065em;
}

.subtitle {
  max-width: 760px;
  margin: 0;
  color: var(--color-text-secondary, #9da8b8);
  font-size: 14px;
  line-height: 1.72;
}

.syncArea {
  display: grid;
  justify-items: end;
  gap: 9px;
  min-width: min(100%, 280px);
}

.syncButton {
  display: flex !important;
  align-items: center;
  gap: 12px;
  width: 100%;
  min-width: 245px;
  min-height: 56px;
  padding: 10px 15px !important;
  cursor: pointer;
  color: #17130d !important;
  border: 1px solid rgba(255, 214, 130, 0.55) !important;
  border-radius: 17px !important;
  background:
    linear-gradient(
      135deg,
      #e3b967,
      #c7943f
    ) !important;
  box-shadow:
    0 13px 30px rgba(201, 154, 78, 0.18),
    inset 0 1px 0 rgba(255, 255, 255, 0.36) !important;
  text-align: left;
  transition:
    transform 160ms ease,
    filter 160ms ease,
    box-shadow 160ms ease;
}

.syncButton:hover:not(:disabled) {
  filter: brightness(1.06);
  transform: translateY(-1px);
  box-shadow:
    0 17px 36px rgba(201, 154, 78, 0.24),
    inset 0 1px 0 rgba(255, 255, 255, 0.42) !important;
}

.syncButton:disabled {
  cursor: not-allowed;
  filter: saturate(0.45);
  opacity: 0.58;
}

.syncButtonIcon {
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  width: 34px;
  height: 34px;
  border: 1px solid rgba(23, 19, 13, 0.16);
  border-radius: 12px;
  background: rgba(23, 19, 13, 0.08);
  font-size: 20px;
  font-weight: 950;
}

.syncButtonText {
  display: grid;
  gap: 2px;
}

.syncButtonText strong {
  font-size: 12px;
  font-weight: 950;
}

.syncButtonText small {
  color: rgba(23, 19, 13, 0.68);
  font-size: 9px;
  font-weight: 800;
}

.syncSuccess,
.syncError {
  max-width: 330px;
  padding: 9px 11px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 800;
  line-height: 1.45;
}

.syncSuccess {
  color: var(--color-sage, #77b396);
  border: 1px solid rgba(105, 168, 139, 0.24);
  background: rgba(105, 168, 139, 0.08);
}

.syncError {
  color: var(--color-danger, #dd7f88);
  border: 1px solid rgba(221, 127, 136, 0.25);
  background: rgba(221, 127, 136, 0.08);
}

.metricGrid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}

.metricTile {
  position: relative;
  overflow: hidden;
  display: grid;
  gap: 8px;
  min-width: 0;
  padding: 17px !important;
  border: 1px solid rgba(210, 220, 240, 0.09) !important;
  border-radius: 20px !important;
  background: rgba(255, 255, 255, 0.032) !important;
  box-shadow: none !important;
}

.metricTile::after {
  content: "";
  position: absolute;
  right: -30px;
  bottom: -50px;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  opacity: 0.28;
}

.metricDefault::after {
  background: rgba(140, 158, 183, 0.25);
}

.metricAccent::after {
  background: rgba(94, 122, 158, 0.38);
}

.metricPositive::after {
  background: rgba(105, 168, 139, 0.3);
}

.metricNegative::after {
  background: rgba(215, 112, 123, 0.27);
}

.metricTop {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.metricLabel {
  color: var(--color-text-secondary, #9da8b8);
  font-size: 10px;
  font-weight: 950;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.metricDot {
  width: 7px;
  height: 7px;
  border: 2px solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  background: rgba(158, 184, 214, 0.76);
}

.metricPositive .metricDot {
  background: var(--color-sage, #69a88b);
}

.metricNegative .metricDot {
  background: var(--color-danger, #d7707b);
}

.metricValue {
  position: relative;
  z-index: 1;
  overflow-wrap: anywhere;
  color: var(--color-text-primary, #f4f6f8);
  font-size: clamp(21px, 2.1vw, 30px);
  font-weight: 950;
  letter-spacing: -0.045em;
}

.metricPositive .metricValue {
  color: var(--color-sage, #77b396);
}

.metricNegative .metricValue {
  color: var(--color-danger, #dd7f88);
}

.metricCaption {
  position: relative;
  z-index: 1;
  color: var(--color-text-secondary, #9da8b8);
  font-size: 10px;
  line-height: 1.5;
}

.ledgerSurface {
  display: grid;
  gap: 17px;
  min-width: 0;
  padding: 20px !important;
  border: 1px solid rgba(210, 220, 240, 0.095) !important;
  border-radius: 26px !important;
  background: rgba(24, 30, 40, 0.96) !important;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.025),
    0 18px 48px rgba(0, 0, 0, 0.13) !important;
}

.surfaceHeader {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18px;
}

.surfaceTitle {
  margin: 5px 0 4px;
  color: var(--color-text-primary, #f4f6f8);
  font-size: 25px;
  letter-spacing: -0.045em;
}

.surfaceDescription {
  margin: 0;
  color: var(--color-text-secondary, #9da8b8);
  font-size: 12px;
}

.surfaceMeta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
  color: var(--color-text-secondary, #9da8b8);
  font-size: 11px;
}

.surfaceMeta strong {
  color: var(--color-text-primary, #f4f6f8);
}

.clearButton {
  padding: 7px 10px;
  color: rgba(190, 214, 241, 0.94);
  border: 1px solid rgba(112, 145, 184, 0.26);
  border-radius: 10px;
  background: rgba(70, 91, 120, 0.1);
  font-size: 10px;
  font-weight: 850;
  text-decoration: none;
}

.filters {
  display: grid;
  grid-template-columns:
    minmax(260px, 1.35fr)
    repeat(3, minmax(145px, 0.55fr))
    auto;
  align-items: end;
  gap: 9px;
  padding: 13px;
  border: 1px solid rgba(210, 220, 240, 0.07);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.022);
}

.field,
.searchField {
  display: grid;
  gap: 6px;
  min-width: 0;
}

.fieldLabel {
  padding-left: 2px;
  color: var(--color-text-secondary, #9da8b8);
  font-size: 9px;
  font-weight: 950;
  letter-spacing: 0.075em;
  text-transform: uppercase;
}

.searchInputWrap {
  position: relative;
  min-width: 0;
}

.searchIcon {
  position: absolute;
  z-index: 1;
  top: 50%;
  left: 13px;
  color: rgba(157, 179, 207, 0.7);
  font-size: 18px;
  transform: translateY(-50%);
  pointer-events: none;
}

.input,
.select {
  width: 100% !important;
  min-width: 0;
  min-height: 43px;
  color: var(--color-text-primary, #f4f6f8) !important;
  border: 1px solid rgba(210, 220, 240, 0.105) !important;
  border-radius: 13px !important;
  background: rgba(10, 15, 22, 0.58) !important;
  box-shadow: none !important;
  font-size: 11px;
  outline: none;
}

.input {
  padding: 10px 12px 10px 40px !important;
}

.select {
  padding: 10px 12px !important;
}

.input:focus,
.select:focus {
  border-color: rgba(112, 145, 184, 0.58) !important;
  box-shadow:
    0 0 0 3px rgba(70, 91, 120, 0.14) !important;
}

.filterButton {
  position: relative;
  align-self: end;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 8px;
  width: 100% !important;
  min-width: 132px;
  height: 43px !important;
  min-height: 43px !important;
  margin: 0 !important;
  padding: 0 18px !important;
  box-sizing: border-box;
  cursor: pointer;
  appearance: none;
  color: #17130d !important;
  border: 1px solid rgba(232, 195, 132, 0.54) !important;
  border-radius: 13px !important;
  background:
    linear-gradient(
      135deg,
      #e2b763 0%,
      #c89542 100%
    ) !important;
  box-shadow:
    0 9px 22px rgba(201, 154, 78, 0.16),
    inset 0 1px 0 rgba(255, 255, 255, 0.32) !important;
  font-family: inherit;
  font-size: 10px !important;
  font-weight: 950 !important;
  line-height: 1 !important;
  letter-spacing: 0.02em;
  text-align: center;
  white-space: nowrap;
  transition:
    transform 150ms ease,
    filter 150ms ease,
    box-shadow 150ms ease,
    border-color 150ms ease;
}

.filterButton::before {
  content: "";
  width: 6px;
  height: 6px;
  flex: 0 0 auto;
  border-radius: 999px;
  background: rgba(23, 19, 13, 0.72);
  box-shadow: 0 0 0 3px rgba(23, 19, 13, 0.08);
}

.filterButton:hover {
  filter: brightness(1.07);
  transform: translateY(-1px);
  border-color: rgba(255, 220, 148, 0.74) !important;
  box-shadow:
    0 13px 28px rgba(201, 154, 78, 0.23),
    inset 0 1px 0 rgba(255, 255, 255, 0.4) !important;
}

.filterButton:active {
  filter: brightness(0.98);
  transform: translateY(0);
  box-shadow:
    0 6px 14px rgba(201, 154, 78, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.26) !important;
}

.filterButton:focus-visible {
  outline: none;
  box-shadow:
    0 0 0 3px rgba(201, 154, 78, 0.18),
    0 12px 26px rgba(201, 154, 78, 0.22) !important;
}

.emptyState {
  display: grid;
  grid-template-columns: minmax(240px, 0.65fr) minmax(320px, 1fr);
  align-items: center;
  gap: 34px;
  min-height: 360px;
  padding: 34px;
  border: 1px dashed rgba(112, 145, 184, 0.25);
  border-radius: 22px;
  background:
    radial-gradient(
      circle at 18% 50%,
      rgba(70, 91, 120, 0.14),
      transparent 34%
    ),
    rgba(255, 255, 255, 0.012);
}

.emptyVisual {
  position: relative;
  display: grid;
  place-items: center;
  min-height: 230px;
}

.emptyRing {
  position: relative;
  z-index: 2;
  display: grid;
  place-items: center;
  width: 118px;
  height: 118px;
  color: rgba(211, 184, 127, 0.95);
  border: 1px solid rgba(201, 154, 78, 0.28);
  border-radius: 50%;
  background:
    radial-gradient(
      circle at 34% 25%,
      rgba(232, 195, 132, 0.22),
      rgba(201, 154, 78, 0.06) 50%,
      rgba(255, 255, 255, 0.018) 72%
    );
  box-shadow:
    0 26px 70px rgba(0, 0, 0, 0.26),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);
  font-size: 43px;
  font-weight: 900;
}

.emptyLineOne,
.emptyLineTwo,
.emptyLineThree {
  position: absolute;
  left: 50%;
  height: 1px;
  border-radius: 999px;
  background:
    linear-gradient(
      90deg,
      transparent,
      rgba(112, 145, 184, 0.35),
      transparent
    );
  transform: translateX(-50%);
}

.emptyLineOne {
  top: 28px;
  width: 84%;
}

.emptyLineTwo {
  bottom: 40px;
  width: 66%;
}

.emptyLineThree {
  bottom: 15px;
  width: 42%;
}

.emptyCopy {
  display: grid;
  gap: 11px;
  max-width: 610px;
}

.emptyCopy h3 {
  margin: 0;
  color: var(--color-text-primary, #f4f6f8);
  font-size: clamp(25px, 3vw, 39px);
  line-height: 1.05;
  letter-spacing: -0.052em;
}

.emptyCopy p {
  margin: 0;
  color: var(--color-text-secondary, #9da8b8);
  font-size: 13px;
  line-height: 1.7;
}

.emptyActions {
  display: flex;
  flex-wrap: wrap;
  gap: 9px;
  margin-top: 5px;
}

.primaryLink,
.secondaryLink {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40px;
  padding: 9px 13px;
  border-radius: 12px;
  font-size: 10px;
  font-weight: 950;
  text-decoration: none;
}

.primaryLink {
  color: #17130d;
  border: 1px solid rgba(232, 195, 132, 0.34);
  background:
    linear-gradient(
      135deg,
      #dfb564,
      #bd8d3e
    );
}

.secondaryLink {
  color: rgba(211, 225, 242, 0.95);
  border: 1px solid rgba(112, 145, 184, 0.26);
  background: rgba(70, 91, 120, 0.1);
}

.tableWrap {
  min-width: 0;
  overflow-x: auto;
  padding-bottom: 3px;
}

.table {
  width: 100%;
  min-width: 1120px;
  border-collapse: separate;
  border-spacing: 0 7px;
}

.table th {
  padding: 0 14px 7px !important;
  color: rgba(143, 161, 185, 0.9);
  font-size: 9px !important;
  font-weight: 950;
  letter-spacing: 0.09em;
  text-align: left;
  text-transform: uppercase;
}

.table td {
  padding: 13px 14px !important;
  color: var(--color-text-secondary, #9da8b8);
  border-top: 1px solid rgba(210, 220, 240, 0.055);
  border-bottom: 1px solid rgba(210, 220, 240, 0.055);
  background: rgba(255, 255, 255, 0.025) !important;
  font-size: 11px;
  vertical-align: middle;
}

.table td:first-child {
  border-left: 1px solid rgba(210, 220, 240, 0.055);
  border-radius: 13px 0 0 13px;
}

.table td:last-child {
  border-right: 1px solid rgba(210, 220, 240, 0.055);
  border-radius: 0 13px 13px 0;
}

.table tbody tr {
  background: transparent !important;
  transition: transform 140ms ease;
}

.table tbody tr:hover td {
  border-color: rgba(112, 145, 184, 0.15);
  background: rgba(70, 91, 120, 0.09) !important;
}

.dateText,
.mutedText {
  color: rgba(143, 161, 185, 0.92);
  white-space: nowrap;
}

.entryCell {
  display: grid;
  gap: 4px;
  min-width: 210px;
  max-width: 330px;
}

.entryCell strong {
  overflow: hidden;
  color: var(--color-text-primary, #f4f6f8);
  font-size: 11px;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entryCell span {
  overflow: hidden;
  color: rgba(143, 161, 185, 0.88);
  font-size: 9px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.categoryPill {
  display: inline-flex;
  max-width: 150px;
  overflow: hidden;
  padding: 6px 8px;
  color: rgba(190, 208, 229, 0.92);
  border: 1px solid rgba(210, 220, 240, 0.075);
  border-radius: 9px;
  background: rgba(255, 255, 255, 0.025);
  font-size: 9px;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 8px;
  border-radius: 999px;
  font-size: 9px;
  font-weight: 950;
  white-space: nowrap;
}

.badgeDot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: currentColor;
}

.creditBadge,
.approvedBadge {
  color: var(--color-sage, #77b396);
  border: 1px solid rgba(105, 168, 139, 0.22);
  background: rgba(105, 168, 139, 0.075);
}

.debitBadge,
.rejectedBadge {
  color: var(--color-danger, #dd7f88);
  border: 1px solid rgba(221, 127, 136, 0.22);
  background: rgba(221, 127, 136, 0.075);
}

.neutralBadge,
.reviewBadge {
  color: rgba(166, 196, 229, 0.96);
  border: 1px solid rgba(112, 145, 184, 0.25);
  background: rgba(70, 91, 120, 0.11);
}

.creditAmount,
.debitAmount,
.neutralAmount {
  font-size: 11px;
  font-weight: 950;
  white-space: nowrap;
}

.creditAmount {
  color: var(--color-sage, #77b396);
}

.debitAmount {
  color: var(--color-danger, #dd7f88);
}

.neutralAmount {
  color: rgba(196, 211, 229, 0.94);
}

.confidenceCell {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 92px;
}

.confidenceCell strong {
  color: rgba(190, 208, 229, 0.92);
  font-size: 9px;
}

.confidenceTrack {
  overflow: hidden;
  width: 46px;
  height: 5px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.055);
}

.confidenceTrack span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background:
    linear-gradient(
      90deg,
      rgba(78, 104, 138, 0.84),
      rgba(119, 179, 150, 0.9)
    );
}

.sourceCell {
  display: grid;
  gap: 4px;
  min-width: 160px;
  max-width: 210px;
}

.sourceCell > span {
  color: rgba(143, 161, 185, 0.9);
  font-size: 8px;
  font-weight: 900;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.sourceCell a {
  display: flex;
  align-items: center;
  gap: 5px;
  overflow: hidden;
  color: rgba(207, 222, 239, 0.96);
  font-size: 9px;
  font-weight: 850;
  text-decoration: none;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sourceCell a small {
  color: rgba(157, 179, 207, 0.82);
}

@media (max-width: 1220px) {
  .metricGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .filters {
    grid-template-columns:
      minmax(240px, 1fr)
      repeat(2, minmax(150px, 0.5fr));
  }

  .field:nth-of-type(4) {
    grid-column: 1 / 2;
  }

  .filterButton {
  position: relative;
  align-self: end;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 8px;
  width: 100% !important;
  min-width: 132px;
  height: 43px !important;
  min-height: 43px !important;
  margin: 0 !important;
  padding: 0 18px !important;
  box-sizing: border-box;
  cursor: pointer;
  appearance: none;
  color: #17130d !important;
  border: 1px solid rgba(232, 195, 132, 0.54) !important;
  border-radius: 13px !important;
  background:
    linear-gradient(
      135deg,
      #e2b763 0%,
      #c89542 100%
    ) !important;
  box-shadow:
    0 9px 22px rgba(201, 154, 78, 0.16),
    inset 0 1px 0 rgba(255, 255, 255, 0.32) !important;
  font-family: inherit;
  font-size: 10px !important;
  font-weight: 950 !important;
  line-height: 1 !important;
  letter-spacing: 0.02em;
  text-align: center;
  white-space: nowrap;
  transition:
    transform 150ms ease,
    filter 150ms ease,
    box-shadow 150ms ease,
    border-color 150ms ease;
}

.filterButton::before {
  content: "";
  width: 6px;
  height: 6px;
  flex: 0 0 auto;
  border-radius: 999px;
  background: rgba(23, 19, 13, 0.72);
  box-shadow: 0 0 0 3px rgba(23, 19, 13, 0.08);
}

.filterButton:hover {
  filter: brightness(1.07);
  transform: translateY(-1px);
