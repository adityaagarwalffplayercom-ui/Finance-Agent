  transform: skewX(-18deg);
}

.syncButton:hover:not(:disabled) {
  transform: translateY(-1px) !important;

  border-color:
    rgba(132, 168, 210, 0.60) !important;

  background:
    linear-gradient(
      135deg,
      rgba(78, 104, 138, 0.54),
      rgba(52, 70, 96, 0.48)
