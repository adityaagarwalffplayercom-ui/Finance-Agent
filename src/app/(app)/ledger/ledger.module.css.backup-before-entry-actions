  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.09),
    0 15px 32px rgba(0, 0, 0, 0.23),
    0 0 0 3px rgba(70, 91, 120, 0.10) !important;
}

.syncButton:active:not(:disabled) {
  transform: translateY(0) !important;

  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.05),
    0 8px 18px rgba(0, 0, 0, 0.17) !important;
}

.syncButton:focus-visible {
  outline: none !important;

  border-color:
    rgba(132, 168, 210, 0.72) !important;

  box-shadow:
    0 0 0 3px rgba(94, 122, 158, 0.18),
    0 14px 30px rgba(0, 0, 0, 0.22) !important;
